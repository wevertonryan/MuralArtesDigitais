# ============================================================
# Mural de Artes Digitais — Variáveis de Ambiente
# Copie este arquivo para ".env" e preencha os valores reais.
# Obtenha as credenciais em: https://console.firebase.google.com
# ============================================================

# --- Firebase Client-Side (Frontend) ---
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# --- Geolocalização (opcional — usado via Firebase Function server-side) ---
# A chave abaixo é usada pela função geoFilter.js para identificar a região do usuário.
# Serviço gratuito: https://ip-api.com (sem chave necessária no plano grátis)
# Deixe em branco para desativar o filtro regional.
GEO_API_BASE_URL=http://ip-api.com/json

# ============================================================
# Mural de Artes Digitais — Variáveis de Ambiente
# Copie este arquivo para ".env" e preencha os valores reais.
# Obtenha as credenciais em: https://supabase.com/dashboard/projects
# ============================================================

# --- Supabase Client-Side (Frontend) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Geolocalização (opcional — usado via Supabase Edge Function server-side) ---
# A chave abaixo é usada para identificar a região do usuário.
# Serviço gratuito: https://ip-api.com (sem chave necessária no plano grátis)
# Deixe em branco para desativar o filtro regional.
GEO_API_BASE_URL=
